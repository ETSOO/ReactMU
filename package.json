    "青岛亿速思维",
    "上海亿商"
  ],
  "author": "ETSOO",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ETSOO/ReactMU/issues"
  },
  "homepage": "https://github.com/ETSOO/ReactMU#readme",
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/react": "^0.5.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@etsoo/appscript": "^1.6.70",
    "@etsoo/notificationbase": "^1.1.72",
    "@etsoo/react": "^1.8.94",
    "@etsoo/shared": "^1.2.87",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.2",
