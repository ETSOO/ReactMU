    "@types/pulltorefreshjs": "^0.1.7",
    "@types/react": "^19.2.17",
    "@types/react-avatar-editor": "^13.0.4",
    "@types/react-dom": "^19.2.3",
    "@types/react-input-mask": "^3.0.6",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
