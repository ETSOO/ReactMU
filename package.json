    "chartjs-plugin-datalabels": "^2.2.0",
    "dompurify": "^3.4.11",
    "eventemitter3": "^5.0.4",
    "pica": "^10.0.2",
    "pulltorefreshjs": "^0.1.22",
    "react": "^19.2.7",
    "react-avatar-editor": "^15.1.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "react-draggable": "^4.7.0",
